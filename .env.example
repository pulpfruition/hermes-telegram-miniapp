# =============================================================================
# Hermes Telegram Mini App — Required Environment Variables
# =============================================================================
# Copy this file to ~/.hermes/.env and fill in your values.
# These can also be set in your systemd service file (see systemd/ directory).
# =============================================================================

# Your Telegram bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram numeric user ID (not your username).
# Get it from @userinfobot (https://t.me/userinfobot)
TELEGRAM_OWNER_ID=YOUR_USER_ID_HERE

# Comma-separated list of Telegram user IDs allowed to use the mini app.
# For single-user: just your ID. For multi-user: comma-separated.
TELEGRAM_ALLOWED_USERS=YOUR_USER_ID_HERE

# API server key — a random secret for Bearer token auth fallback.
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# This is used when accessing the API outside of Telegram (e.g. from a browser).
API_SERVER_KEY=YOUR_API_KEY_HERE
